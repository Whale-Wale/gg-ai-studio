rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPlatformAdmin() {
      return isSignedIn() && getUserData().role == 'PlatformAdmin';
    }

    function isProfessionalOfTenant(tenantId) {
      return isSignedIn() && getUserData().role == 'Professional' && getUserData().tenantId == tenantId;
    }

    function isUserOfTenant(tenantId) {
      return isSignedIn() && getUserData().tenantId == tenantId;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation for ID poisoning
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collections ---

    match /tenants/{tenantId} {
      allow read: if isSignedIn() && (isPlatformAdmin() || isUserOfTenant(tenantId) || resource.data.isTest == true);
      allow write: if isPlatformAdmin();
      allow delete: if isSignedIn() && resource.data.isTest == true;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isPlatformAdmin() || isOwner(userId) || (getUserData().tenantId == resource.data.tenantId));
      allow create: if isSignedIn(); // Initial profile creation
      allow update: if isSignedIn() && (isPlatformAdmin() || isOwner(userId));
    }

    match /feedbacks/{feedbackId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.tenantId == getUserData().tenantId);
    }

    match /patients/{patientId} {
      allow read, write: if isSignedIn();
    }
    match /patients/{patientId}/records/{recordId} {
      allow read, write: if isSignedIn();
    }
    match /patients/{patientId}/summaries/{summaryId} {
      allow read, write: if isSignedIn();
    }
    match /patients/{patientId}/notes/{noteId} {
      allow read, write: if isSignedIn();
    }
    match /patients/{patientId}/prescriptions/{prescriptionId} {
      allow read, write: if isSignedIn();
    }

    match /alerts/{alertId} {
      allow read: if isSignedIn() && (isPlatformAdmin() || isProfessionalOfTenant(resource.data.tenantId) || resource.data.isTest == true);
      allow create: if isSignedIn(); // Simulation
      allow update: if isSignedIn() && (isPlatformAdmin() || isProfessionalOfTenant(resource.data.tenantId));
      allow delete: if isSignedIn() && resource.data.isTest == true;
    }
  }
}
