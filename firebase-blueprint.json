{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Multi-tenant organization (Clinic/Gym)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "plan": { "type": "string", "enum": ["Basic", "Premium"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "userCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "plan", "status"]
    },
    "User": {
      "title": "User",
      "description": "System user associated with a tenant",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["PlatformAdmin", "Professional", "User"] },
        "tenantId": { "type": "string" },
        "patientId": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["email", "role", "tenantId"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient or client monitored by a professional",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "dob": { "type": "string" },
        "status": { "type": "string", "enum": ["Normal", "Critical"] },
        "professionalId": { "type": "string" },
        "lastSyncAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tenantId", "name", "status"]
    },
    "HealthRecord": {
      "title": "Health Record",
      "description": "Periodic health data from wearable devices",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "tenantId": { "type": "string" },
        "heartRate": { "type": "number" },
        "steps": { "type": "integer" },
        "sleepQuality": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "tenantId", "heartRate", "timestamp"]
    },
    "Alert": {
      "title": "Health Alert",
      "description": "Triggered when health metrics are out of safe range",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "tenantId": { "type": "string" },
        "heartRate": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["New", "Read"] }
      },
      "required": ["patientId", "tenantId", "heartRate", "timestamp", "status"]
    },
    "AISummary": {
      "title": "AI Summary",
      "description": "AI-generated health status summary",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "tenantId": { "type": "string" },
        "summary": { "type": "string" },
        "risks": { "type": "array", "items": { "type": "string" } },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Organization details"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Profile of a system user"
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient metadata within a tenant"
    },
    "/patients/{patientId}/records/{recordId}": {
      "schema": "HealthRecord",
      "description": "Time-series health data"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Active alerts for professionals"
    },
    "/patients/{patientId}/summaries/{summaryId}": {
      "schema": "AISummary",
      "description": "Health summaries generated by AI"
    }
  }
}
